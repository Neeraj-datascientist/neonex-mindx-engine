# Database (if you use Prisma locally)
# DATABASE_URL="file:./dev.db"

# Primary: Gmail SMTP (App Password, not your normal Gmail password)
GMAIL_USER=your-account@gmail.com
GMAIL_PASS="xxxx xxxx xxxx xxxx"

# Optional: where to deliver (defaults to GMAIL_USER)
ENQUIRY_TO_EMAIL=you@example.com

# Optional custom SMTP
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

SMTP_FROM_NAME=NeoNex Minds Website

# Fallback: Web3Forms (browser, when SMTP fails)
# Use either name (same Form Access Key from web3forms.com dashboard):
NEXT_PUBLIC_WEB3FORMS_KEY=your_form_access_key_here
# WEB3FORMS_ACCESS_KEY=your_form_access_key_here
