# Database Connection (PostgreSQL)
# Get your connection string from Neon.tech, Supabase, or Vercel Postgres
DATABASE_URL="postgresql://user:password@hostname:port/dbname?sslmode=require"

# Primary: Gmail SMTP (App Password, not your normal Gmail password)
GMAIL_USER=your-account@gmail.com
GMAIL_PASS="xxxx xxxx xxxx xxxx"

# Optional: where to deliver (defaults to GMAIL_USER)
ENQUIRY_TO_EMAIL=you@example.com

# Optional custom SMTP
# SMTP_HOST=
# SMTP_PORT=587
# 🐘 Database Configuration (Vercel Postgres / Neon / Supabase)
# Get this connection string from the Vercel Postgres dashboard.
DATABASE_URL="postgres://default:password@ep-host.region.aws.neon.tech:5432/verceldb?sslmode=require"

# 📧 Email Notification Settings (Nodemailer)
# SMTP_USER: Your email address (e.g., Gmail)
# SMTP_PASS: Your App Password (not your primary password)
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# (Optional) Custom SMTP settings
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_FROM_NAME="NeoNex Website"

# (Optional) Recipient settings
# ENQUIRY_TO_EMAIL="recipient1@gmail.com,recipient2@gmail.com"

# 🧩 Web3Forms Fallback (Frontend)
# If SMTP fails, the frontend will try to use this key.
NEXT_PUBLIC_WEB3FORMS_KEY="your-web3forms-access-key"
WEB3FORMS_ACCESS_KEY="your-web3forms-access-key"
